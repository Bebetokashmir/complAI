# ComplAI Environment Variables
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to git

# Vercel AI Gateway API Key (local dev only)
# On Vercel deployments, auth is automatic via OIDC — no key needed
# Get from: vercel.com → your team → AI Gateway → API Keys
# Or run: vercel env pull .env.local
AI_GATEWAY_API_KEY=your_ai_gateway_api_key_here

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
